{
  "crons": [
    {
      "path": "/api/keepalive",
      "schedule": "*/10 * * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{"type": "host", "value": "www.artimagehub.com"}],
      "destination": "https://artimagehub.com/:path*",
      "permanent": true
    },
    {
      "source": "/pricing",
      "destination": "/#pricing",
      "permanent": true
    }
  ]
}
